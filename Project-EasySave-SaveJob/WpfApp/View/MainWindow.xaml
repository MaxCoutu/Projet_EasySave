<Window x:Class="Projet.Wpf.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Projet.Wpf.Localization"
        xmlns:local="clr-namespace:Projet.Wpf.View"
        Title="{loc:Loc menu_title}"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FF19173D"
        Foreground="White">

    <Window.Resources>
        <local:FolderNameConverter x:Key="FolderNameConverter"/>

        <!-- Style boutons arrondis -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Height" Value="85"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour le bouton Retour -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate pour la vue principale -->
        <DataTemplate x:Key="MainViewTemplate">
            <Grid Margin="30,20,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="299"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <StackPanel Grid.Column="0" Margin="0,74,4,0">
                    <!-- Create -->
                    <Button Style="{StaticResource RoundedButton}"
                            Background="#FF7428D7"
                            Command="{Binding ShowAddJobViewCommand}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc menu_create}"
                                       Width="180" TextWrapping="Wrap"/>
                            <Viewbox Width="57" Height="57" Margin="10,0,0,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M8 9.00006H6.2C5.0799 9.00006 4.51984 9.00006 4.09202 9.21805C3.71569 9.40979 3.40973 9.71575 3.21799 10.0921C3 10.5199 3 11.08 3 12.2001V17.8001C3 18.9202 3 19.4802 3.21799 19.908C3.40973 20.2844 3.71569 20.5903 4.09202 20.7821C4.51984 21.0001 5.07989 21.0001 6.2 21.0001H17.787C18.9071 21.0001 19.4671 21.0001 19.895 20.7821C20.2713 20.5903 20.5772 20.2844 20.769 19.908C20.987 19.4802 20.987 18.9202 20.987 17.8001V12.0001M6 15.0001H6.01M10 15H10.01M11.5189 12.8946L12.8337 12.6347C13.5432 12.4945 13.8979 12.4244 14.2287 12.2953C14.5223 12.1807 14.8013 12.0318 15.06 11.8516C15.3514 11.6487 15.607 11.393 16.1184 10.8816L21.2668 5.73321C21.9541 5.04596 21.9541 3.9317 21.2668 3.24444C20.5796 2.55719 19.4653 2.55719 18.7781 3.24445L13.5416 8.48088C13.0625 8.96004 12.8229 9.19963 12.6294 9.47121C12.4576 9.71232 12.3131 9.97174 12.1986 10.2447C12.0696 10.5522 11.9921 10.8821 11.837 11.5417L11.5189 12.8946Z" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </StackPanel>
                    </Button>

                    <!-- Choose -->
                    <Button Style="{StaticResource RoundedButton}"
                            Background="#FF0E73C5"
                            Command="{Binding ShowChooseJobViewCommand}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc menu_choose}"
                                       Width="180" TextWrapping="Wrap"/>
                            <Viewbox Width="57" Height="57" Margin="10,0,0,0">
                                <Canvas Width="16" Height="16">
                                  
                                    <Path Data="M8.16923 2.00234C8.11301 2.00078 8.0566 2 8 2C4.68629 2 2 4.68629 2 8C2 11.3137 4.68629 14 8 14C11.3137 14 14 11.3137 14 8C14 7.9434 13.9992 7.88699 13.9977 7.83077L15.7642 6.06422C15.9182 6.68407 16 7.33249 16 8C16 12.4183 12.4183 16 8 16C3.58172 16 0 12.4183 0 8C0 3.58172 3.58172 0 8 0C8.66751 0 9.31593 0.0817526 9.93578 0.235791L8.16923 2.00234Z" Fill="White"/>
                                    
                                    <Path Data="M4 7.99996C4 6.13612 5.27477 4.57002 7 4.12598V6.26752C6.4022 6.61333 6 7.25968 6 7.99996C6 9.10453 6.89543 9.99996 8 9.99996C8.74028 9.99996 9.38663 9.59776 9.73244 8.99996H11.874C11.4299 10.7252 9.86384 12 8 12C5.79086 12 4 10.2091 4 7.99996Z" Fill="White"/>
                                   
                                    <Path Data="M14 2L13 0L10 3V4.58579L7.79289 6.79289L9.20711 8.20711L11.4142 6H13L16 3L14 2Z" Fill="White"/>
                                </Canvas>
                            </Viewbox>
                        </StackPanel>
                    </Button>

                    <!-- Run All -->
                    <Button Style="{StaticResource RoundedButton}"
                            Background="#FFF5AC6E"
                            Command="{Binding RunAllCmd}"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc menu_runall}"
                                       Width="180" TextWrapping="Wrap"/>
                            <Viewbox Width="57" Height="57" Margin="10,0,0,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M16,24H0V8h4V4h4V0h16v16h-4v4h-4V24z M2,22h12V10H2V22z M16,18h2V6H6v2h10V18z M20,14h2V2H10v2h10V14z" Fill="White"/>
                                </Canvas>
                            </Viewbox>
                        </StackPanel>
                    </Button>

                    <!-- Spacer -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0">
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="{loc:Loc menu_settings}"
                                Cursor="Hand">
                            <Viewbox Width="44" Height="44">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Width="6" Height="6" Canvas.Left="9" Canvas.Top="9" Stroke="White" StrokeThickness="1.5"/>
                                    <Path Data="M3.66122 10.6392 C4.13377 10.9361 4.43782 11.4419 4.43782 11.9999 C4.13376 13.0638 3.66122 13.3607 3.33966 13.5627 C3.13248 13.7242 2.98508 13.9163 2.66217 14.3372 C2.51966 14.869 2.5889 15.3949 2.64082 15.7893 C2.87379 16.1928 3.33973 16.9999 3.80568 17.8069 C4.03865 18.2104 4.35426 18.4526 4.77508 18.7755 C5.30694 18.918 5.83284 18.8488 6.07287 18.8172 C6.31628 18.7185 6.65196 18.5411 7.14544 18.2803 C7.73558 18.2699 8.21895 18.549 8.70227 18.8281 C8.98827 19.3443 9.00912 19.902 9.02332 20.2815 C9.05958 20.5417 9.15224 20.7654 9.35523 21.2554 C9.74458 21.6448 10.2346 21.8478 10.6022 22 C11.0681 22 12 22 12.9319 22 C13.3978 22 13.7654 21.8478 14.2554 21.6448 C14.6448 21.2554 14.8478 20.7654 14.9404 20.5417 C14.9767 20.2815 14.9909 19.9021 15.0117 19.3443 C15.2977 18.8281 15.7811 18.549 16.2644 18.27 C16.8545 18.2804 17.3479 18.5412 17.6837 18.7186 C17.9271 18.8173 18.1671 18.8489 18.693 18.9182 C19.2249 18.7756 19.6457 18.4527 19.9613 18.2106 C20.1943 17.807 20.6603 17 20.8677 16.6407 C21.029 16.3614 21.1486 16.1272 21.1486 16.1272 M20.3387 13.3608 C19.8662 13.0639 19.5622 12.5581 19.5621 12.0001 C19.5621 11.442 19.8662 10.9361 20.3387 10.6392 C20.6603 10.4372 20.8674 10.2757 21.0148 10.0836 C21.3377 9.66278 21.4802 9.13092 21.411 8.60502 C21.3591 8.2106 21.1261 7.80708 20.6601 7.00005 C20.1942 6.19301 19.9612 5.7895 19.6456 5.54732 C19.2248 5.22441 18.6929 5.0819 18.167 5.15113 C17.927 5.18274 17.6836 5.2814 17.3479 5.45883 C16.8544 5.71964 16.2643 5.73004 15.781 5.45096 C15.2977 5.1719 15.0117 4.6557 14.9909 4.09803 C14.9767 3.71852 14.9404 3.45835 14.8478 3.23463 C14.6448 2.74458 14.2554 2.35523 13.7654 2.15224 C13.3978 2 12.9319 2 12 2 C11.0681 2 10.6022 2 10.2346 2.15224 C9.74458 2.35523 9.35523 2.74458 9.15224 3.23463 C9.05958 3.45833 9.02332 3.71848 9.00912 4.09794 C8.98826 4.65566 8.70225 5.17191 8.21891 5.45096 C7.73557 5.73002 7.14548 5.71959 6.65205 5.4588 C6.31633 5.28136 6.0729 5.18269 5.83285 5.15108 C5.30695 5.08185 4.77509 5.22436 4.35427 5.54727 C4.03866 5.78945 3.80569 6.19297 3.33974 7 C3.13231 7.35929 2.97105 7.63859 2.85138 7.87273" Stroke="White" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding SetFrenchCommand}"
                                Margin="60,0,0,0"
                                Cursor="Hand">
                            <Viewbox Width="45" Height="43">
                                <Canvas Width="36" Height="36">
                                    <Path Data="M36 27a4 4 0 0 1-4 4h-8V5h8a4 4 0 0 1 4 4v18z" Fill="#ED2939"/>
                                    <Path Data="M4 5a4 4 0 0 0-4 4v18a4 4 0 0 0 4 4h8V5H4z" Fill="#002495"/>
                                    <Path Data="M12 5h12v26H12z" Fill="#EEE"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0"
                                Command="{Binding SetEnglishCommand}"
                                Margin="10,20,0,0"
                                Cursor="Hand">
                            <Viewbox Width="45" Height="42">
                                <Canvas Width="28" Height="28" Margin="0,-4,0,0">
                                    <!-- Appliquer le clip-path (rectangle avec coins arrondis) -->
                                    <Canvas.Clip>
                                        <RectangleGeometry Rect="0,0,28,20" RadiusX="2" RadiusY="2"/>
                                    </Canvas.Clip>
                                    <!-- Fond bleu -->
                                    <Rectangle Width="28" Height="20" Fill="#0A17A7"/>
                                    <!-- Chemin blanc (diagonales) -->
                                    <Path Data="M-1.28244 -1.91644L10.6667 6.14335V-1.33333H17.3334V6.14335L29.2825 -1.91644L30.7737 0.294324L21.3263 6.66667H28V13.3333H21.3263L30.7737 19.7057L29.2825 21.9165L17.3334 13.8567V21.3333H10.6667V13.8567L-1.28244 21.9165L-2.77362 19.7057L6.67377 13.3333H2.95639e-05V6.66667H6.67377L-2.77362 0.294324L-1.28244 -1.91644Z" Fill="White"/>
                                    <!-- Lignes rouges (diagonales) -->
                                    <Path Data="M18.668 6.33219L31.3333 -2" Stroke="#DB1F35" StrokeThickness="0.666667" StrokeLineJoin="Round" StrokeEndLineCap="Round"/>
                                    <Path Data="M20.0128 13.6975L31.3666 21.3503" Stroke="#DB1F35" StrokeThickness="0.666667" StrokeLineJoin="Round" StrokeEndLineCap="Round"/>
                                    <Path Data="M8.00555 6.31046L-3.83746 -1.67099" Stroke="#DB1F35" StrokeThickness="0.666667" StrokeLineJoin="Round" StrokeEndLineCap="Round"/>
                                    <Path Data="M9.29006 13.6049L-3.83746 22.3105" Stroke="#DB1F35" StrokeThickness="0.666667" StrokeLineJoin="Round" StrokeEndLineCap="Round"/>
                                    <!-- Croix rouge -->
                                    <Path Data="M0 12H12V20H16V12H28V8H16V0H12V8H0V12Z" Fill="#E6273E"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- MAIN PANEL -->
                <Border Grid.Column="1"
                        Background="#FF25234E"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#FF3B3A5E"
                        BorderThickness="1"
                        Margin="30,10,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Title -->
                            <TextBlock Text="{loc:Loc recent_title}"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#CCFFFFFF"
                                       Opacity="0.8"
                                       Margin="0,0,0,20"
                                       HorizontalAlignment="Center"/>

                            <!-- Items list -->
                            <ItemsControl ItemsSource="{Binding RecentJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12"
                                                Background="#FF33345A"
                                                Margin="0,0,0,10"
                                                Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                        <TextBlock Text="{Binding Strategy.Type}"
                                                                   FontSize="18"
                                                                   FontStyle="Italic"
                                                                   Foreground="#CCCCCC"
                                                                   Margin="25,0,0,0"/>
                                                    </StackPanel>

                                                    <TextBlock FontSize="12"
                                                               Opacity="0.7"
                                                               TextWrapping="Wrap"
                                                               Margin="0,10,0,5">
                                                        <Run Text="{loc:Loc src_label}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding SourceDir, Converter={StaticResource FolderNameConverter}}"/>
                                                    </TextBlock>

                                                    <TextBlock FontSize="12"
                                                               Opacity="0.7"
                                                               TextWrapping="Wrap">
                                                        <Run Text="{loc:Loc dst_label}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding TargetDir, Converter={StaticResource FolderNameConverter}}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Width="25" Height="25"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RunJobCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Cursor="Hand"
                                                        ToolTip="{loc:Loc play_tooltip}">
                                                    <Path Data="M0,0 L0,20 L18,10 Z"
                                                          Fill="White"
                                                          Stretch="Uniform"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Contenu principal -->
        <ContentControl x:Name="MainContentControl"
                        Content="{Binding CurrentViewModel}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource MainViewTemplate}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="AddJobViewModel">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Border Background="#FF25234E"
                                                Width="700" Height="400"
                                                CornerRadius="15"
                                                Padding="20"
                                                BorderBrush="#FF3B3A5E"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Cursor="Hand">
                                            <ContentPresenter Content="{Binding}"/>
                                        </Border>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="ChooseJobViewModel">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Border Background="#FF25234E"
                                                Width="700" Height="400"
                                                CornerRadius="15"
                                                Padding="20"
                                                BorderBrush="#FF3B3A5E"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Cursor="Hand">
                                            <ContentPresenter Content="{Binding}"/>
                                        </Border>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- Bouton Retour -->
        <Button Command="{Binding ReturnToMainViewCommand}" 
                Height="50" Width="50" 
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="50,0,0,30"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource BackButtonStyle}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="AddJobViewModel">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="ChooseJobViewModel">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Viewbox Width="50" Height="50">
                <Canvas Width="32" Height="32">
                    <Path Data="M584,1065 C576.268,1065 570,1058.73 570,1051 C570,1043.27 576.268,1037 584,1037 C591.732,1037 598,1043.27 598,1051 C598,1058.73 591.732,1065 584,1065 L584,1065 Z M584,1035 C575.163,1035 568,1042.16 568,1051 C568,1059.84 575.163,1067 584,1067 C592.837,1067 600,1059.84 600,1051 C600,1042.16 592.837,1035 584,1035 L584,1035 Z M588.535,1042.46 C588.145,1042.07 587.512,1042.07 587.121,1042.46 L579.465,1050.12 C579.225,1050.36 579.15,1050.69 579.205,1051 C579.15,1051.31 579.225,1051.64 579.465,1051.88 L587.121,1059.54 C587.512,1059.93 588.145,1059.93 588.535,1059.54 C588.926,1059.14 588.926,1058.51 588.535,1058.12 L581.414,1051 L588.535,1043.88 C588.926,1043.49 588.926,1042.86 588.535,1042.46 L588.535,1042.46 Z" Fill="White">
                        <Path.RenderTransform>
                            <TranslateTransform X="-568" Y="-1035"/>
                        </Path.RenderTransform>
                    </Path>
                </Canvas>
            </Viewbox>
        </Button>
    </Grid>
</Window>