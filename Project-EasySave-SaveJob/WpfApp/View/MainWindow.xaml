<Window x:Class="Projet.Wpf.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Projet.Wpf.Localization"
        xmlns:local="clr-namespace:Projet.Wpf.View"
        Title="{loc:Loc menu_title}"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FF19173D"
        Foreground="White">

	<Window.Resources>
		<local:FolderNameConverter x:Key="FolderNameConverter"/>
		<local:ProgressBarVisibilityConverter x:Key="ProgressBarVisibilityConverter"/>
		<local:ViewModelTypeConverter x:Key="ViewModelTypeConverter"/>

		<!-- Styles -->
		<Style x:Key="RoundedButton" TargetType="Button">
			<Setter Property="Margin" Value="0,0,0,20"/>
			<Setter Property="Height" Value="85"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="Black"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Padding" Value="20,0"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Background" Value="Gray"/>
			<Setter Property="Opacity" Value="0.8"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="12">
							<ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="BackButtonStyle" TargetType="Button">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Cursor="Hand">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- DataTemplate pour la vue principale -->
		<DataTemplate x:Key="MainViewTemplate">
			<Grid Margin="30,20,20,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="299"/>
					<ColumnDefinition/>
				</Grid.ColumnDefinitions>

				<!-- SIDEBAR -->
				<StackPanel Grid.Column="0" Margin="0,74,4,0"
                            Visibility="{Binding DataContext.CurrentViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModelTypeConverter}, ConverterParameter=MainViewModel}">
					<!-- Ajouter une sauvegarde -->
					<Button Style="{StaticResource RoundedButton}"
                            Background="#FF7428D7"
                            Command="{Binding ShowAddJobViewCommand}"
                            Cursor="Hand">
						<StackPanel Orientation="Horizontal">
							<Viewbox Width="24" Height="24" Margin="0,0,10,0">
								<Canvas Width="24" Height="24">
									<Path Data="M12,2V22 M2,12H22"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
								</Canvas>
							</Viewbox>
							<TextBlock Text="{loc:Loc menu_create}" />
						</StackPanel>
					</Button>

					<!-- Sélectionner une sauvegarde -->
					<Button Style="{StaticResource RoundedButton}"
                            Background="#FF0E73C5"
                            Command="{Binding ShowChooseJobViewCommand}"
                            Cursor="Hand">
						<StackPanel Orientation="Horizontal">
							<Viewbox Width="24" Height="24" Margin="0,0,10,0">
								<Canvas Width="24" Height="24">
									<Path Data="M4,12L10,18L20,6"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Fill="Transparent"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
								</Canvas>
							</Viewbox>
							<TextBlock Text="{loc:Loc menu_choose}" />
						</StackPanel>
					</Button>

					<!-- Lancer toutes les sauvegardes -->
					<Button Style="{StaticResource RoundedButton}"
                            Background="#FFF5AC6E"
                            Command="{Binding RunAllCmd}"
                            Cursor="Hand">
						<StackPanel Orientation="Horizontal">
							<Viewbox Width="24" Height="24" Margin="0,0,10,0">
								<Canvas Width="24" Height="24">
									<Path Data="M4,4L20,12L4,20Z" Fill="White"/>
								</Canvas>
							</Viewbox>
							<TextBlock Text="{loc:Loc menu_runall}" />
						</StackPanel>
					</Button>

					<!-- Paramètres et langues -->
					<StackPanel Orientation="Horizontal" Margin="0,20,0,0">
						<Button Background="Transparent" BorderThickness="0"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="{loc:Loc menu_settings}"
                                Cursor="Hand">
							<Viewbox Width="24" Height="24">
								<Canvas Width="24" Height="24">
									<Path Data="M12,2A10,10 0 1,0 12,22A10,10 0 1,0 12,2Z"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Fill="Transparent"/>
									<Ellipse Width="6" Height="6" Canvas.Left="9" Canvas.Top="9" Fill="White"/>
								</Canvas>
							</Viewbox>
						</Button>
						<Button Background="Transparent" BorderThickness="0"
                                Command="{Binding SetFrenchCommand}"
                                Margin="20,0,0,0"
                                Cursor="Hand">
							<Image Width="24" Height="16" Source="/WpfApp;component/Assets/fr_flag.png"/>
						</Button>
						<Button Background="Transparent" BorderThickness="0"
                                Command="{Binding SetEnglishCommand}"
                                Margin="10,0,0,0"
                                Cursor="Hand">
							<Image Width="24" Height="16" Source="/WpfApp;component/Assets/gb_flag.png"/>
						</Button>
					</StackPanel>
				</StackPanel>

				<!-- MAIN PANEL -->
				<Border Grid.Column="1"
                        Background="#FF25234E"
                        CornerRadius="15"
                        Padding="20"
                        BorderBrush="#FF3B3A5E"
                        BorderThickness="1"
                        Margin="30,10,0,10">
					<ScrollViewer VerticalScrollBarVisibility="Disabled">
						<StackPanel>
							<TextBlock Text="{loc:Loc recent_title}"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="#CCFFFFFF"
                                       Opacity="0.8"
                                       Margin="0,0,0,20"
                                       HorizontalAlignment="Center"/>
							<ItemsControl ItemsSource="{Binding RecentJobs}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border CornerRadius="12"
                                                Background="#FF33345A"
                                                Margin="0,0,0,10"
                                                Padding="15">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition/>
													<ColumnDefinition Width="Auto"/>
												</Grid.ColumnDefinitions>
												<StackPanel>
													<StackPanel Orientation="Horizontal">
														<TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="White"/>
														<TextBlock Text="{Binding Strategy.Type}" FontSize="18" FontStyle="Italic" Foreground="#CCCCCC" Margin="25,0,0,0"/>
													</StackPanel>
													<TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap" Margin="0,10,0,5">
														<Run Text="{loc:Loc src_label}"/>
														<Run Text=" "/>
														<Run Text="{Binding SourceDir, Converter={StaticResource FolderNameConverter}}"/>
													</TextBlock>
													<TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap">
														<Run Text="{loc:Loc dst_label}"/>
														<Run Text=" "/>
														<Run Text="{Binding TargetDir, Converter={StaticResource FolderNameConverter}}"/>
													</TextBlock>
													<!-- Barre de progression par job -->
													<ProgressBar Minimum="0"
                                                                 Maximum="100"
                                                                 Height="16"
                                                                 Margin="0,10,0,0"
                                                                 Value="{Binding DataContext.JobProgress[Name], RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}">
														<ProgressBar.Visibility>
															<MultiBinding Converter="{StaticResource ProgressBarVisibilityConverter}">
																<Binding Path="DataContext.RunningJobs" RelativeSource="{RelativeSource AncestorType=Window}"/>
																<Binding Path="Name"/>
															</MultiBinding>
														</ProgressBar.Visibility>
													</ProgressBar>
												</StackPanel>
												<Button Grid.Column="1"
                                                        Width="25" Height="25"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RunJobCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Cursor="Hand"
                                                        ToolTip="{loc:Loc play_tooltip}">
													<Path Data="M0,0 L0,20 L18,10 Z" Fill="White" Stretch="Uniform"/>
												</Button>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</ScrollViewer>
				</Border>
			</Grid>
		</DataTemplate>
	</Window.Resources>

	<Grid>
		<ContentControl x:Name="MainContentControl"
                        Content="{Binding CurrentViewModel}">
			<ContentControl.Style>
				<Style TargetType="ContentControl">
					<Setter Property="ContentTemplate" Value="{StaticResource MainViewTemplate}"/>
					<Style.Triggers>
						<DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="AddJobViewModel">
							<Setter Property="ContentTemplate">
								<Setter.Value>
									<DataTemplate>
										<Border Background="#FF25234E"
                                                Width="700" Height="400"
                                                CornerRadius="15"
                                                Padding="20"
                                                BorderBrush="#FF3B3A5E"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Cursor="Hand">
											<ContentPresenter Content="{Binding}"/>
										</Border>
									</DataTemplate>
								</Setter.Value>
							</Setter>
						</DataTrigger>
						<DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="ChooseJobViewModel">
							<Setter Property="ContentTemplate">
								<Setter.Value>
									<DataTemplate>
										<Border Background="#FF25234E"
                                                Width="700" Height="400"
                                                CornerRadius="15"
                                                Padding="20"
                                                BorderBrush="#FF3B3A5E"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Cursor="Hand">
											<ContentPresenter Content="{Binding}"/>
										</Border>
									</DataTemplate>
								</Setter.Value>
							</Setter>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</ContentControl.Style>
		</ContentControl>

		<!-- Bouton Retour -->
		<Button Command="{Binding ReturnToMainViewCommand}"
                Height="50" Width="50"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="50,0,0,30"
                Cursor="Hand">
			<Button.Style>
				<Style TargetType="Button" BasedOn="{StaticResource BackButtonStyle}">
					<Setter Property="Visibility" Value="Collapsed"/>
					<Style.Triggers>
						<DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="AddJobViewModel">
							<Setter Property="Visibility" Value="Visible"/>
						</DataTrigger>
						<DataTrigger Binding="{Binding CurrentViewModel, Converter={x:Static local:ViewModelTypeConverter.Instance}}" Value="ChooseJobViewModel">
							<Setter Property="Visibility" Value="Visible"/>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Button.Style>
			<Viewbox Width="50" Height="50">
				<Canvas Width="32" Height="32">
					<Path Data="M584,1065 C576.268,1065 570,1058.73 570,1051 C570,1043.27 576.268,1037 584,1037 C591.732,1037 598,1043.27 598,1051 C598,1058.73 591.732,1065 584,1065 L584,1065 Z M584,1035 C575.163,1035 568,1042.16 568,1051 C568,1059.84 575.163,1067 584,1067 C592.837,1067 600,1059.84 600,1051 C600,1042.16 592.837,1035 584,1035 L584,1035 Z M588.535,1042.46 C588.145,1042.07 587.512,1042.07 587.121,1042.46 L579.465,1050.12 C579.225,1050.36 579.15,1050.69 579.205,1051 C579.15,1051.31 579.225,1051.64 579.465,1051.88 L587.121,1059.54 C587.512,1059.93 588.145,1059.93 588.535,1059.54 C588.926,1059.14 588.926,1058.51 588.535,1058.12 L581.414,1051 L588.535,1043.88 C588.926,1043.49 588.926,1042.86 588.535,1042.46 L588.535,1042.46 Z" Fill="White">
						<Path.RenderTransform>
							<TranslateTransform X="-568" Y="-1035"/>
						</Path.RenderTransform>
					</Path>
				</Canvas>
			</Viewbox>
		</Button>
	</Grid>
</Window>